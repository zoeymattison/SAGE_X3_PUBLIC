# ajustement du délai de preparation suivant  les jours ouvrés du site
$DELAI_PREPARATION
Local Integer WDELAI
Local Integer JOUR
Local Date    WDATE
Raz WDATE
WDELAI = [F:ITF]PRPLTI
If WDELAI = 0
   Return
Endif
If [F:FCY]UVYDAY(0) <>2 &
&  [F:FCY]UVYDAY(1) <>2 &
&  [F:FCY]UVYDAY(2) <>2 &
&  [F:FCY]UVYDAY(3) <>2 &
&  [F:FCY]UVYDAY(4) <>2 &
&  [F:FCY]UVYDAY(5) <>2 &
&  [F:FCY]UVYDAY(6) <>2
   Return
Endif
WDATE = [F:SOQ]SHIDAT
Raz WDELAI
For I = 1 To [F:ITF]PRPLTI
$DATEPRE
    WDELAI +=1
    WDATE = WDATE -1
    JCOUR = dayn(WDATE)
    If [F:FCY]UVYDAY(JCOUR-1) <> 2
       Goto DATEPRE
    Endif
Next
Return
#                                                          # hcb 120105 fin

