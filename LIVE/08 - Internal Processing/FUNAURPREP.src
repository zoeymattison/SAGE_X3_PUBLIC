Subprog AM_BPCORDSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M]BPCORDEND="" [M]BPCORDEND=VALEUR Endif
   Actzo [M]BPAADDSTR
Else
   Diszo [M]BPAADDSTR
Endif
End

Subprog AM_BPAADDSTR(VALEUR)
