######################################################################################

Subprog ALIM_ETAT(IDOC,NBRCOPIE,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ)
Value    Integer IDOC
Value    Integer NBRCOPIE
Variable Char    WARP_RPTCOD()(0..)
Variable Integer WARP_NUMREQ  (1..)
Variable Integer WARP_NUMLIG  (1..)
Variable Integer WARP_SEQREQ  (1..)
#----- Variables locales -----#
Local    Char    ETAT(GLONARP) : ETAT    =WARP_RPTCOD(0)
Local    Integer REQUETE       : REQUETE =WARP_NUMREQ(max(IDOC,1))
Local    Integer LIGNE         : LIGNE   =WARP_NUMLIG(max(IDOC,1))
Local    Integer SEQUENCE      : SEQUENCE=WARP_SEQREQ(max(IDOC,1))
Local    Integer I
Local    Integer OK
Local    Libelle WADXLOG

#----- Récupération du numéro de la requête si 1ère fois -----#
If REQUETE=0  REQUETE=uniqid([ARP]) : Endif
#----- Faire progresser la séquence si nécessaire -----#
If ETAT<>WARP_RPTCOD(max(IDOC,1))  SEQUENCE+=1 : Endif

   If !adxlog
      [L]WADXLOG=0
      Call DEBTRANS From GLOCK
   Else
      [L]WADXLOG=1
   Endif
   #----- Màj indicateur d'impression et chargement AREPORTM -----#
   #Gosub ALIM_ETAT From =[F:ARP]TRTINI
   #-----

   If [L]WADXLOG=0
      GOK=1
      Trbegin [PRL]
   Endif
   #----- Création des enregistrements dans la table AREPORTM -----#
   Raz [F:ARM]
   [F:ARM]NUMREQ = REQUETE
   [F:ARM]USR    = GUSER
   [F:ARM]RPTCOD = ETAT
   [F:ARM]NUMLIG = LIGNE
   [F:ARM]SEQREQ = SEQUENCE
   [F:ARM]CLEA1  = [F:PRL]PRLNUM
   [F:ARM]CREDAT = date$
   #-----
   For I=1 To max(NBRCOPIE,1)
      [F:ARM]NUMLIG+=1
      Gosub ALIMETAT_PE From ETAT
      Write [ARM]
      If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
   Next I
   #-----
   If fstat
      If [L]WADXLOG=0 Rollback Endif
      End
   Endif
   LIGNE   =[F:ARM]NUMLIG
   SEQUENCE=[F:ARM]SEQREQ
   If [L]WADXLOG=0
      Commit
   Endif

   #----- Actualisation des paramètres de l'état -----#
   WARP_RPTCOD(max(IDOC,1))=ETAT
   WARP_NUMREQ(max(IDOC,1))=REQUETE
   WARP_NUMLIG(max(IDOC,1))=LIGNE
   WARP_SEQREQ(max(IDOC,1))=SEQUENCE
   #-----

End

#-- X3Suivi 75115 : Passage du Type livraison de commande à BP --#
###########################
Subprog AM_SIMU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
   #-- Genération BP
   Grizo [M]ALLTYPFLG, ORDRUP, SHIRUP
   Grizo [M]GENBPR
   Raz   [M]GENBPR
   #-- Impression BON PREPA
   Grizo [M]BPRFLG, BPRNAM, BPRDEN, BPRSRV, BPRIMP
   Raz   [M]BPRFLG, BPRNAM, BPRDEN, BPRSRV, BPRIMP
   #-- Impression LISTE PREPA
   Grizo [M]LPRFLG, LPRNAM, LPRDEN, LPRSRV, LPRIMP
   Raz   [M]LPRFLG, LPRNAM, LPRDEN, LPRSRV, LPRIMP
   Affzo [M]
Else
   Actzo [M]GENBPR
   #-- Impression LISTE PREPA
   Actzo [M]LPRFLG, LPRNAM, LPRDEN
Endif
End
