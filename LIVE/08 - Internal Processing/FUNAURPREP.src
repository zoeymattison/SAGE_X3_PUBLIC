Subprog AP_LPRFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Raz [M]LPRNAM, [M]LPRDEN, [M]LPRIMP, [M]LPRSRV
   Diszo [M]LPRNAM, LPRDEN
Else
   If vireblc([M]LPRNAM,2)=""
      Call INIT_ARL("PRH", [M]LPRNAM) From TRTVENIMP
      Actzo [M]LPRNAM, LPRDEN
   Endif
Endif
Affzo [M]LPRNAM, LPRDEN, LPRSRV, LPRIMP
End

